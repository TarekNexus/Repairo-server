# Server Port
PORT=5000

# Database URL (Demo)
DATABASE_URL="postgresql://demo_user:demo_password@demo-db.example.com/demo_db?sslmode=require&channel_binding=require"

# Authentication
BETTER_AUTH_SECRET=demo_auth_secret
BETTER_AUTH_URL=http://localhost:5000

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Environment
NODE_ENV=development

# Google OAuth (Demo)
GOOGLE_CLIENT_ID=demo_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=demo_google_client_secret

# Stripe (Demo)
STRIPE_SECRET_KEY=sk_test_demo_secret_key
STRIPE_WEBHOOK_SECRET=whsec_demo_webhook_secret